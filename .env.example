# ============================================================
#  profile-analyst — environment configuration
#  Copy to .env and fill in secrets before running.
#  .env is git-ignored; this file is committed (no secrets).
#
#  In docker compose the URIs below use service names.
#  For bare-metal runs swap neo4j→localhost, ollama→localhost,
#  mlflow→127.0.0.1, postgres→localhost, minio→localhost.
# ============================================================

# ── App / Pipeline ───────────────────────────────────────────
LLM_BACKEND=anthropic            # anthropic | ollama  (Stage 3 backend selector)
ANTHROPIC_API_KEY=               # REQUIRED when LLM_BACKEND=anthropic
ALLOW_NONCOMPLIANT=false         # set true only for test fixtures, never production
API_PORT=8000                    # FastAPI port published by app-api service

# ── Neo4j (spec 0002) ────────────────────────────────────────
NEO4J_URI=bolt://neo4j:7687      # bare-metal: bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=                  # REQUIRED — set a strong password
NEO4J_DATABASE=neo4j
# Consumed by the neo4j container image (must match NEO4J_PASSWORD above):
NEO4J_AUTH=neo4j/${NEO4J_PASSWORD}

# ── Ollama (spec 0003 / spec 0005) ───────────────────────────
OLLAMA_HOST=http://ollama:11434  # bare-metal: http://localhost:11434
OLLAMA_CYPHER_MODEL=qwen2.5-coder:32b   # NL→Cypher role (~20 GB VRAM)
                                         # lighter: mistral-small (~12 GB)
OLLAMA_FEATURES_MODEL=qwen2.5:14b        # Stage 3 feature extraction
OLLAMA_EMBED_MODEL=nomic-embed-text      # Stage 8 embeddings (768-dim)
OLLAMA_KEEP_ALIVE=10m
# Models pulled by the ollama-pull init service:
OLLAMA_PULL_MODELS=qwen2.5-coder:32b,qwen2.5:14b,nomic-embed-text
ASK_MAX_ROWS=200
ASK_TIMEOUT_MS=5000
ASK_FALLBACK=true

# ── Hybrid RAG (spec 0005) ────────────────────────────────────
EMBED_DIMENSIONS=768
RAG_MODES=vector,graph,keyword
RAG_VECTOR_K=50
RAG_KEYWORD_K=50
RAG_GRAPH_K=50
RAG_RRF_K=60
RAG_MODE_WEIGHTS=vector:1.0,graph:1.0,keyword:1.0
RAG_FUSED_TOP_K=20
RAG_RERANK=false

# ── MLflow / Observability (spec 0006) ────────────────────────
OBSERVABILITY_ENABLED=true       # set false in CI / tests
MLFLOW_TRACKING_URI=http://mlflow:5000   # bare-metal: http://127.0.0.1:5000
MLFLOW_EXPERIMENT=influencer-rag-observability
MLFLOW_EXPERIMENT_EVAL=influencer-rag-eval

# MLflow backend (PostgreSQL):
POSTGRES_USER=mlflow
POSTGRES_PASSWORD=               # REQUIRED
POSTGRES_DB=mlflow
MLFLOW_BACKEND_STORE_URI=postgresql://mlflow:${POSTGRES_PASSWORD}@postgres:5432/mlflow

# MLflow artifact store (MinIO / S3-compatible):
MLFLOW_ARTIFACTS_DESTINATION=s3://mlflow/
MINIO_ROOT_USER=                 # REQUIRED
MINIO_ROOT_PASSWORD=             # REQUIRED (min 8 chars)
MINIO_DEFAULT_BUCKET=mlflow
MLFLOW_S3_ENDPOINT_URL=http://minio:9000
AWS_ACCESS_KEY_ID=${MINIO_ROOT_USER}
AWS_SECRET_ACCESS_KEY=${MINIO_ROOT_PASSWORD}
