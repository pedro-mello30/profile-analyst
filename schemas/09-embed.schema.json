{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://profile-analyst/schemas/09-embed.schema.json",
  "title": "Stage 8 Embed Manifest",
  "description": "Manifest emitted by Stage 8 EMBED recording embedding backfill results for one run.",
  "type": "object",
  "required": [
    "handle",
    "embedded_at",
    "embedding_model",
    "embedding_model_version",
    "dimensions",
    "similarity_function",
    "counts",
    "data_egress"
  ],
  "properties": {
    "handle": { "type": "string", "minLength": 1 },
    "embedded_at": { "type": "string", "format": "date-time" },
    "embedding_model": { "type": "string", "minLength": 1 },
    "embedding_model_version": { "type": "string", "minLength": 1 },
    "dimensions": { "type": "integer", "minimum": 1 },
    "similarity_function": { "type": "string", "enum": ["cosine", "euclidean", "dot"] },
    "counts": {
      "type": "object",
      "required": ["creator", "media"],
      "properties": {
        "creator": {
          "type": "object",
          "required": ["embedded", "skipped", "reembedded"],
          "properties": {
            "embedded":   { "type": "integer", "minimum": 0 },
            "skipped":    { "type": "integer", "minimum": 0 },
            "reembedded": { "type": "integer", "minimum": 0 }
          }
        },
        "media": {
          "type": "object",
          "required": ["embedded", "skipped", "reembedded"],
          "properties": {
            "embedded":   { "type": "integer", "minimum": 0 },
            "skipped":    { "type": "integer", "minimum": 0 },
            "reembedded": { "type": "integer", "minimum": 0 }
          }
        }
      }
    },
    "data_egress": { "type": "string", "enum": ["local-only"] }
  },
  "additionalProperties": false
}
